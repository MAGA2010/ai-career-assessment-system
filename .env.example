# OpenAI 配置
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://yyds.215.im/v1  # 如果你的OpenAI网关地址已包含 /v1，则写完整URL；否则写 https://yyds.215.im
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini

# Supabase 配置（Vercel Serverless 后端使用）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 本地 Python 后端可选配置
# 使用 Supabase/PostgreSQL 时，请设置为你的 Supabase 连接字符串，通常类似：
# postgresql://username:password@dbhost:5432/database?sslmode=require
# 如果密码包含特殊字符（例如 ?、#、&），请先进行 URL 编码
DATABASE_URL=sqlite:///./career_assessment.db
